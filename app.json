{
  "expo": {
    "name": "Branded By Kyle",
    "slug": "branded-by-kyle",
    "scheme": "brandedbykyle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/7b25c61f-edfd-4567-a346-cb9b175c7378.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/7b25c61f-edfd-4567-a346-cb9b175c7378.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brandedbykyletattoo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.brandedbykyletattoo.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/7b25c61f-edfd-4567-a346-cb9b175c7378.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D1B2A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}